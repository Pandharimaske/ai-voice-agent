# ─────────────────────────────────────────────────────────
#  ARIA — Audio Reasoning Intelligence Agent
#  Copy this file to .env and fill in your keys.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────

# ── Groq (recommended — free tier, fastest inference) ────
GROQ_API_KEY=gsk_your_groq_key_here

# ── OpenAI (optional) ────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key_here

# ── Anthropic (optional) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# ── LangSmith Observability (optional but recommended) ───
# Get your key at: https://smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_your_langsmith_key_here
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=AI-Voice-Agent
